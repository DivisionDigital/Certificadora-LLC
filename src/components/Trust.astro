---
const pillars = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    title: 'Cobertura Nacional',
    description: 'Atendemos empresas fabricantes e importadores en todo el territorio colombiano, sin importar la ubicación de su operación.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.153-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
    title: 'Pruebas de Laboratorio',
    description: 'Realizamos ensayos técnicos bajo estándares nacionales e internacionales para validar el desempeño y seguridad de su producto.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
    title: 'Auditorías Técnicas',
    description: 'Nuestros expertos evalúan sus procesos productivos y sistemas de gestión de calidad para asegurar el cumplimiento normativo continuo.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
    title: 'Capacitación Especializada',
    description: 'Formamos a su equipo técnico y comercial en el entendimiento de los reglamentos y los procesos de certificación.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    title: 'Normativa Vigente',
    description: 'Trabajamos siempre alineados con las últimas versiones de los reglamentos RETIE, RETILAP y RETIQ, y sus actualizaciones.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>`,
    title: 'Aliado Estratégico',
    description: 'Nos integramos como parte de su equipo, brindando acompañamiento técnico durante todo el ciclo de vida de su certificación.',
  },
];
---

<section id="nosotros" class="relative py-24 lg:py-32" style="clip-path: inset(0);">
  <!-- Fixed parallax background — uses position:fixed + clip-path on parent -->
  <div
    id="trust-parallax-bg"
    class="trust-fixed-bg absolute -top-px -bottom-px inset-x-0"
    aria-hidden="true"
    style="background-image: url('/images/inicio/background.webp');"
  ></div>
  <!-- Overlay for readability -->
  <div class="absolute -top-px -bottom-px inset-x-0 z-[1]" aria-hidden="true" style="background: var(--trust-overlay-bg);"></div>

  <div class="relative z-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-light-blue-bg)] text-[var(--color-primary-blue)] text-xs font-semibold rounded-full uppercase tracking-widest mb-4">
        ¿Por qué LLC?
      </span>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-[var(--color-text-primary)] mb-4">
        Más que una certificadora,<br class="hidden md:block"/> un socio técnico de confianza
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto leading-relaxed">
        Combinamos experiencia técnica, rigor normativo y acompañamiento personalizado
        para que usted pueda certificar sus productos con total tranquilidad.
      </p>
    </div>

    <!-- Grid de pilares -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {pillars.map((pillar, i) => (
        <div class="group bg-[var(--color-surface-card)] border border-[var(--color-border)] rounded-2xl p-7 hover:shadow-lg hover:border-[var(--color-border-hover)] transition-all duration-200">
          <div class="w-12 h-12 bg-[var(--color-light-blue-bg)] rounded-xl flex items-center justify-center mb-5 group-hover:bg-[var(--color-primary-blue)] transition-colors duration-200">
            <svg
              class="w-6 h-6 text-[var(--color-primary-blue)] group-hover:text-white transition-colors duration-200"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              viewBox="0 0 24 24"
              set:html={pillar.icon}
            />
          </div>
          <h3 class="text-base font-bold text-[var(--color-text-primary)] mb-2">{pillar.title}</h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{pillar.description}</p>
        </div>
      ))}
    </div>

    <!-- Banner de confianza -->
    <div
      class="mt-16 rounded-2xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-8"
      style="background: linear-gradient(135deg, #0B1F4B 0%, #1040A0 100%);"
    >
      <div class="flex-1 text-center md:text-left">
        <h3 class="text-white font-bold text-2xl md:text-3xl mb-3">
          Confíe en expertos con trayectoria comprobada
        </h3>
        <p class="text-slate-300 text-base leading-relaxed">
          LLC Certificaciones ha acompañado a fabricantes e importadores en el proceso de cumplimiento
          de los reglamentos técnicos colombianos, garantizando acceso legal al mercado nacional.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0">
        <a
          href="#servicios"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-[var(--color-accent-amber)] hover:bg-[var(--color-accent-amber-hover)] text-[var(--color-primary-navy)] font-bold rounded-xl transition-all duration-200 text-sm"
        >
          Ver servicios
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl border border-white/30 transition-all duration-200 text-sm"
        >
          Contáctenos
        </a>
      </div>
    </div>
  </div>
  </div>
</section>

<style>
  .trust-fixed-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
    z-index: 0;
    will-change: transform;
  }

  @media (max-width: 1023px) {
    .trust-fixed-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
  }
</style>
