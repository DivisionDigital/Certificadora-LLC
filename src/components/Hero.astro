---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center overflow-hidden"
  style="background: linear-gradient(135deg, #0B1F4B 0%, #0D2860 50%, #1040A0 100%);"
>
  <!-- Patrón geométrico SVG de fondo -->
  <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
        <pattern id="dots" width="30" height="30" patternUnits="userSpaceOnUse">
          <circle cx="15" cy="15" r="1.5" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
      <rect width="100%" height="100%" fill="url(#dots)"/>
    </svg>
  </div>

  <!-- Efecto radial de luz -->
  <div
    class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-10"
    style="background: radial-gradient(circle, #1E6FE8 0%, transparent 70%); transform: translate(30%, -30%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full opacity-10"
    style="background: radial-gradient(circle, #F59E0B 0%, transparent 70%); transform: translate(-30%, 30%);"
    aria-hidden="true"
  ></div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-24 lg:pt-40 lg:pb-32 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- ── Col izquierda: texto ── -->
      <div>
        <div id="hero-badge-pill" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 mb-8">
          <div class="w-2 h-2 rounded-full bg-[#F59E0B] animate-pulse"></div>
          <span class="text-white/90 text-sm font-medium">Certificadora acreditada a nivel nacional</span>
        </div>

        <h1 id="hero-h1" class="text-white font-extrabold leading-tight mb-6"
          style="font-size: clamp(2.25rem, 5vw, 3.5rem);">
          Aliado estratégico para la
          <span class="text-[#F59E0B]"> certificación</span> de productos
          eléctricos y electrónicos
        </h1>

        <p id="hero-p" class="text-slate-300 text-lg leading-relaxed mb-10">
          RETIE · RETILAP · RETIQ · Normas Voluntarias — Cobertura nacional.
          Ofrecemos auditorías, pruebas de laboratorio y capacitación especializada
          para garantizar el cumplimiento normativo de sus productos.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            id="hero-cta-1"
            href="#servicios"
            class="inline-flex items-center gap-2 px-7 py-4 bg-[#F59E0B] hover:bg-[#FBBF24] text-[#0B1F4B] font-bold rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            Ver Servicios
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a
            id="hero-cta-2"
            href="/certificados"
            class="inline-flex items-center gap-2 px-7 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl border border-white/30 hover:border-white/50 transition-all duration-200 hover:-translate-y-0.5"
          >
            Consultar Certificados
          </a>
        </div>

        <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-6 pt-10 border-t border-white/10">
          {[
            { value: 'RETIE',   label: 'Reglamento eléctrico'   },
            { value: 'RETILAP', label: 'Iluminación y alumbrado' },
            { value: 'RETIQ',   label: 'Etiquetado energético'   },
            { value: 'NV',      label: 'Normas Voluntarias'      },
          ].map(stat => (
            <div class="hero-stat text-center">
              <div class="text-[#F59E0B] font-extrabold text-2xl mb-1">{stat.value}</div>
              <div class="text-slate-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Col derecha: Card Stack ── -->
      <div id="hero-visual" class="hidden lg:flex flex-col items-center justify-center gap-5" style="opacity:0">

        <!-- Hint superior -->
        <p class="text-white/40 text-xs font-medium tracking-widest uppercase flex items-center gap-2 select-none">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
          </svg>
          Arrastra · Toca para voltear
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </p>

        <!-- Deck container -->
        <div id="card-deck" class="relative w-full max-w-[340px]" style="height:440px; perspective:1200px;">

          <!-- ── CARTA 0: RETIE ── -->
          <div class="cert-card absolute inset-0 select-none" data-idx="0"
            style="box-shadow:0 24px 64px rgba(0,0,0,0.55), 0 4px 16px rgba(0,0,0,0.35);">
            <div class="cert-card-inner w-full h-full rounded-2xl">
              <!-- FRENTE -->
              <div class="cert-card-face cert-card-front absolute inset-0 rounded-2xl overflow-hidden"
                style="background:linear-gradient(160deg,#0D2F7A 0%,#061A4A 100%); border:1px solid rgba(96,165,250,0.30);">
                <!--
                  📸 SLOT IMAGEN — CARTA RETIE
                  Reemplaza este bloque por:
                  <img src="/images/card-retie.jpg" alt="RETIE" class="w-full object-cover" style="height:58%;" />
                  Tamaño recomendado: 340 × 256 px
                -->
                <div class="w-full flex items-center justify-center" style="height:58%; background:linear-gradient(135deg,rgba(96,165,250,0.10) 0%,rgba(16,40,100,0.45) 100%); border-bottom:1px solid rgba(96,165,250,0.15);">
                  <div class="flex flex-col items-center gap-2" style="opacity:0.35;">
                    <svg class="w-11 h-11" style="color:#93C5FD;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3 9.75h18M3 12h18M3 14.25h18"/>
                    </svg>
                    <span style="color:#93C5FD; font-size:11px; font-weight:500;">340 × 256 px</span>
                  </div>
                </div>
                <div style="padding:20px 24px 16px;">
                  <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px;">
                    <span style="color:#F59E0B; font-weight:900; font-size:22px; letter-spacing:-0.5px;">RETIE</span>
                    <span style="padding:2px 8px; border-radius:20px; font-size:10px; font-weight:600; color:#93C5FD; background:rgba(30,64,175,0.5); border:1px solid rgba(96,165,250,0.3);">Reglamento</span>
                  </div>
                  <p style="color:rgba(255,255,255,0.55); font-size:13px; line-height:1.4; margin-bottom:10px;">Reglamento Técnico de Instalaciones Eléctricas</p>
                  <div style="display:flex; align-items:center; gap:5px; color:rgba(147,197,253,0.5); font-size:11px; font-weight:500;">
                    <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-6-6m0 0l6-6m-6 6h12"/>
                    </svg>
                    Toca para ver productos
                  </div>
                </div>
              </div>
              <!-- REVERSO -->
              <div class="cert-card-face cert-card-back absolute inset-0 rounded-2xl"
                style="background:linear-gradient(160deg,#1040A0 0%,#0B1F4B 100%); border:1px solid rgba(96,165,250,0.40); padding:28px 28px 24px;">
                <div style="color:#60A5FA; font-weight:900; font-size:20px; margin-bottom:4px;">RETIE</div>
                <div style="color:rgba(255,255,255,0.45); font-size:11px; margin-bottom:20px;">Productos certificables bajo este reglamento</div>
                <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;">
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></span>Tableros eléctricos</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></span>Transformadores de distribución</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></span>Conductores y cables eléctricos</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></span>Redes eléctricas internas</li>
                </ul>
                <div style="margin-top:auto; padding-top:20px; border-top:1px solid rgba(255,255,255,0.10); color:rgba(255,255,255,0.28); font-size:11px; text-align:center; position:absolute; bottom:20px; left:28px; right:28px;">Toca de nuevo para volver</div>
              </div>
            </div>
          </div>

          <!-- ── CARTA 1: RETILAP ── -->
          <div class="cert-card absolute inset-0 select-none" data-idx="1"
            style="box-shadow:0 24px 64px rgba(0,0,0,0.55), 0 4px 16px rgba(0,0,0,0.35);">
            <div class="cert-card-inner w-full h-full rounded-2xl">
              <div class="cert-card-face cert-card-front absolute inset-0 rounded-2xl overflow-hidden"
                style="background:linear-gradient(160deg,#7C2D12 0%,#431407 100%); border:1px solid rgba(252,211,77,0.28);">
                <!--
                  📸 SLOT IMAGEN — CARTA RETILAP
                  Reemplaza este bloque por:
                  <img src="/images/card-retilap.jpg" alt="RETILAP" class="w-full object-cover" style="height:58%;" />
                -->
                <div class="w-full flex items-center justify-center" style="height:58%; background:linear-gradient(135deg,rgba(252,211,77,0.09) 0%,rgba(120,45,18,0.45) 100%); border-bottom:1px solid rgba(252,211,77,0.14);">
                  <div class="flex flex-col items-center gap-2" style="opacity:0.35;">
                    <svg class="w-11 h-11" style="color:#FDE68A;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
                    </svg>
                    <span style="color:#FDE68A; font-size:11px; font-weight:500;">340 × 256 px</span>
                  </div>
                </div>
                <div style="padding:20px 24px 16px;">
                  <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px;">
                    <span style="color:#FCD34D; font-weight:900; font-size:22px; letter-spacing:-0.5px;">RETILAP</span>
                    <span style="padding:2px 8px; border-radius:20px; font-size:10px; font-weight:600; color:#FDE68A; background:rgba(120,53,15,0.6); border:1px solid rgba(252,211,77,0.28);">Reglamento</span>
                  </div>
                  <p style="color:rgba(255,255,255,0.55); font-size:13px; line-height:1.4; margin-bottom:10px;">Reglamento Técnico de Iluminación y Alumbrado Público</p>
                  <div style="display:flex; align-items:center; gap:5px; color:rgba(253,230,138,0.45); font-size:11px; font-weight:500;">
                    <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-6-6m0 0l6-6m-6 6h12"/>
                    </svg>
                    Toca para ver productos
                  </div>
                </div>
              </div>
              <div class="cert-card-face cert-card-back absolute inset-0 rounded-2xl"
                style="background:linear-gradient(160deg,#92400E 0%,#431407 100%); border:1px solid rgba(252,211,77,0.40); padding:28px 28px 24px;">
                <div style="color:#FCD34D; font-weight:900; font-size:20px; margin-bottom:4px;">RETILAP</div>
                <div style="color:rgba(255,255,255,0.45); font-size:11px; margin-bottom:20px;">Productos certificables bajo este reglamento</div>
                <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;">
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#FCD34D;flex-shrink:0;"></span>Luminarias LED industriales</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#FCD34D;flex-shrink:0;"></span>Lámparas de alumbrado público</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#FCD34D;flex-shrink:0;"></span>Drivers y balastos electrónicos</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#FCD34D;flex-shrink:0;"></span>Sistemas de iluminación decorativa</li>
                </ul>
                <div style="margin-top:auto; padding-top:20px; border-top:1px solid rgba(255,255,255,0.10); color:rgba(255,255,255,0.28); font-size:11px; text-align:center; position:absolute; bottom:20px; left:28px; right:28px;">Toca de nuevo para volver</div>
              </div>
            </div>
          </div>

          <!-- ── CARTA 2: RETIQ ── -->
          <div class="cert-card absolute inset-0 select-none" data-idx="2"
            style="box-shadow:0 24px 64px rgba(0,0,0,0.55), 0 4px 16px rgba(0,0,0,0.35);">
            <div class="cert-card-inner w-full h-full rounded-2xl">
              <div class="cert-card-face cert-card-front absolute inset-0 rounded-2xl overflow-hidden"
                style="background:linear-gradient(160deg,#064E3B 0%,#022C22 100%); border:1px solid rgba(52,211,153,0.28);">
                <!--
                  📸 SLOT IMAGEN — CARTA RETIQ
                  Reemplaza este bloque por:
                  <img src="/images/card-retiq.jpg" alt="RETIQ" class="w-full object-cover" style="height:58%;" />
                -->
                <div class="w-full flex items-center justify-center" style="height:58%; background:linear-gradient(135deg,rgba(52,211,153,0.09) 0%,rgba(6,78,59,0.45) 100%); border-bottom:1px solid rgba(52,211,153,0.14);">
                  <div class="flex flex-col items-center gap-2" style="opacity:0.35;">
                    <svg class="w-11 h-11" style="color:#6EE7B7;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/>
                    </svg>
                    <span style="color:#6EE7B7; font-size:11px; font-weight:500;">340 × 256 px</span>
                  </div>
                </div>
                <div style="padding:20px 24px 16px;">
                  <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px;">
                    <span style="color:#34D399; font-weight:900; font-size:22px; letter-spacing:-0.5px;">RETIQ</span>
                    <span style="padding:2px 8px; border-radius:20px; font-size:10px; font-weight:600; color:#6EE7B7; background:rgba(6,78,59,0.7); border:1px solid rgba(52,211,153,0.28);">Reglamento</span>
                  </div>
                  <p style="color:rgba(255,255,255,0.55); font-size:13px; line-height:1.4; margin-bottom:10px;">Reglamento Técnico de Etiquetado Energético</p>
                  <div style="display:flex; align-items:center; gap:5px; color:rgba(110,231,183,0.45); font-size:11px; font-weight:500;">
                    <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-6-6m0 0l6-6m-6 6h12"/>
                    </svg>
                    Toca para ver productos
                  </div>
                </div>
              </div>
              <div class="cert-card-face cert-card-back absolute inset-0 rounded-2xl"
                style="background:linear-gradient(160deg,#065F46 0%,#022C22 100%); border:1px solid rgba(52,211,153,0.40); padding:28px 28px 24px;">
                <div style="color:#34D399; font-weight:900; font-size:20px; margin-bottom:4px;">RETIQ</div>
                <div style="color:rgba(255,255,255,0.45); font-size:11px; margin-bottom:20px;">Productos certificables bajo este reglamento</div>
                <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;">
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#34D399;flex-shrink:0;"></span>Aires acondicionados</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#34D399;flex-shrink:0;"></span>Refrigeradores y congeladores</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#34D399;flex-shrink:0;"></span>Lavadoras domésticas</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#34D399;flex-shrink:0;"></span>Televisores y monitores</li>
                </ul>
                <div style="margin-top:auto; padding-top:20px; border-top:1px solid rgba(255,255,255,0.10); color:rgba(255,255,255,0.28); font-size:11px; text-align:center; position:absolute; bottom:20px; left:28px; right:28px;">Toca de nuevo para volver</div>
              </div>
            </div>
          </div>

          <!-- ── CARTA 3: Normas Voluntarias ── -->
          <div class="cert-card absolute inset-0 select-none" data-idx="3"
            style="box-shadow:0 24px 64px rgba(0,0,0,0.55), 0 4px 16px rgba(0,0,0,0.35);">
            <div class="cert-card-inner w-full h-full rounded-2xl">
              <div class="cert-card-face cert-card-front absolute inset-0 rounded-2xl overflow-hidden"
                style="background:linear-gradient(160deg,#4C1D95 0%,#2E1065 100%); border:1px solid rgba(167,139,250,0.28);">
                <!--
                  📸 SLOT IMAGEN — CARTA NORMAS VOLUNTARIAS
                  Reemplaza este bloque por:
                  <img src="/images/card-nv.jpg" alt="Normas Voluntarias" class="w-full object-cover" style="height:58%;" />
                -->
                <div class="w-full flex items-center justify-center" style="height:58%; background:linear-gradient(135deg,rgba(167,139,250,0.09) 0%,rgba(76,29,149,0.45) 100%); border-bottom:1px solid rgba(167,139,250,0.14);">
                  <div class="flex flex-col items-center gap-2" style="opacity:0.35;">
                    <svg class="w-11 h-11" style="color:#C4B5FD;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
                    </svg>
                    <span style="color:#C4B5FD; font-size:11px; font-weight:500;">340 × 256 px</span>
                  </div>
                </div>
                <div style="padding:20px 24px 16px;">
                  <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px;">
                    <span style="color:#A78BFA; font-weight:900; font-size:22px; letter-spacing:-0.5px;">N. Voluntarias</span>
                    <span style="padding:2px 8px; border-radius:20px; font-size:10px; font-weight:600; color:#C4B5FD; background:rgba(76,29,149,0.7); border:1px solid rgba(167,139,250,0.28);">Voluntaria</span>
                  </div>
                  <p style="color:rgba(255,255,255,0.55); font-size:13px; line-height:1.4; margin-bottom:10px;">Certificación bajo Normas Técnicas Colombianas</p>
                  <div style="display:flex; align-items:center; gap:5px; color:rgba(196,181,253,0.45); font-size:11px; font-weight:500;">
                    <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-6-6m0 0l6-6m-6 6h12"/>
                    </svg>
                    Toca para ver productos
                  </div>
                </div>
              </div>
              <div class="cert-card-face cert-card-back absolute inset-0 rounded-2xl"
                style="background:linear-gradient(160deg,#5B21B6 0%,#2E1065 100%); border:1px solid rgba(167,139,250,0.40); padding:28px 28px 24px;">
                <div style="color:#A78BFA; font-weight:900; font-size:20px; margin-bottom:4px;">Normas Voluntarias</div>
                <div style="color:rgba(255,255,255,0.45); font-size:11px; margin-bottom:20px;">Productos certificables bajo NTC</div>
                <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;">
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#A78BFA;flex-shrink:0;"></span>Enchufes e interruptores</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#A78BFA;flex-shrink:0;"></span>Breakers y protecciones eléctricas</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#A78BFA;flex-shrink:0;"></span>Cables de baja y media tensión</li>
                  <li style="display:flex; align-items:center; gap:12px; color:rgba(255,255,255,0.80); font-size:14px;"><span style="width:7px;height:7px;border-radius:50%;background:#A78BFA;flex-shrink:0;"></span>Tomacorrientes y clavijas</li>
                </ul>
                <div style="margin-top:auto; padding-top:20px; border-top:1px solid rgba(255,255,255,0.10); color:rgba(255,255,255,0.28); font-size:11px; text-align:center; position:absolute; bottom:20px; left:28px; right:28px;">Toca de nuevo para volver</div>
              </div>
            </div>
          </div>

        </div>
        <!-- fin #card-deck -->

        <!-- Indicador de posición (dots) -->
        <div id="card-dots" class="flex items-center gap-2">
          <div class="deck-dot rounded-full bg-white transition-all duration-300" style="width:20px;height:8px;opacity:1;"></div>
          <div class="deck-dot rounded-full bg-white transition-all duration-300" style="width:8px;height:8px;opacity:0.35;"></div>
          <div class="deck-dot rounded-full bg-white transition-all duration-300" style="width:8px;height:8px;opacity:0.35;"></div>
          <div class="deck-dot rounded-full bg-white transition-all duration-300" style="width:8px;height:8px;opacity:0.35;"></div>
        </div>

      </div>
      <!-- fin #hero-visual -->

    </div>
  </div>

  <!-- Wave bottom -->
  <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 60L1440 60L1440 30C1200 60 960 0 720 20C480 40 240 10 0 30L0 60Z" fill="white"/>
    </svg>
  </div>
</section>

<style>
  .cert-card { cursor: grab; }
  .cert-card:active { cursor: grabbing; }
  .cert-card-inner {
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .cert-card.is-flipped .cert-card-inner {
    transform: rotateY(180deg);
  }
  .cert-card-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .cert-card-back {
    transform: rotateY(180deg);
  }
</style>

<script>
  import gsap from 'gsap';
  import { Draggable } from 'gsap/Draggable';
  gsap.registerPlugin(Draggable);

  // ─── Entrada del texto (col izquierda) ───────────────────────────────
  gsap.set('#hero-badge-pill', { opacity: 0, y: -20 });
  gsap.set('#hero-h1',         { opacity: 0, y: 35  });
  gsap.set('#hero-p',          { opacity: 0, y: 25  });
  gsap.set('#hero-cta-1',      { opacity: 0, y: 20, scale: 0.95 });
  gsap.set('#hero-cta-2',      { opacity: 0, y: 20, scale: 0.95 });
  gsap.set('.hero-stat',       { opacity: 0, y: 15  });
  gsap.set('#hero-visual',     { opacity: 0 });

  const tl = gsap.timeline({ delay: 0.25, defaults: { ease: 'power3.out' } });
  tl.to('#hero-badge-pill', { opacity: 1, y: 0, duration: 0.55 })
    .to('#hero-h1',          { opacity: 1, y: 0, duration: 0.70 }, '-=0.30')
    .to('#hero-p',           { opacity: 1, y: 0, duration: 0.60 }, '-=0.40')
    .to('#hero-cta-1',       { opacity: 1, y: 0, scale: 1, duration: 0.45, ease: 'back.out(1.5)' }, '-=0.25')
    .to('#hero-cta-2',       { opacity: 1, y: 0, scale: 1, duration: 0.45, ease: 'back.out(1.5)' }, '-=0.35')
    .to('.hero-stat',        { opacity: 1, y: 0, duration: 0.35, stagger: 0.09 }, '-=0.20')
    .to('#hero-visual',      { opacity: 1, duration: 0.50 }, 0.50)
    .add(initDeck, 0.80);

  // ─── Card Deck ────────────────────────────────────────────────────────
  var cards       = Array.from(document.querySelectorAll<HTMLElement>('.cert-card'));
  var order       = [0, 1, 2, 3];  // order[0] = índice de la carta en el tope
  var isAnimating = false;
  var wasDragged  = false;
  var drags: Draggable[] = [];

  // Posiciones de apilado para cada slot (0 = tope)
  var STACK = [
    { y:  0, rotation:  0, scale: 1.00, opacity: 1.00, zIndex: 4 },
    { y: 10, rotation: -2, scale: 0.97, opacity: 0.88, zIndex: 3 },
    { y: 20, rotation: -4, scale: 0.94, opacity: 0.68, zIndex: 2 },
    { y: 30, rotation: -6, scale: 0.91, opacity: 0.00, zIndex: 1 },
  ];

  function initDeck() {
    if (!cards.length) return;

    order.forEach(function(cardIdx, slot) {
      var s = STACK[slot];
      gsap.set(cards[cardIdx], { x: 0, y: s.y, rotation: s.rotation, scale: s.scale, opacity: s.opacity, zIndex: s.zIndex });
    });
    // Entrada de cartas desde abajo
    for (var i = 0; i < 3; i++) {
      gsap.from(cards[order[i]], {
        y: STACK[i].y + 50,
        opacity: 0,
        duration: 0.65,
        delay: i * 0.10,
        ease: 'power3.out',
      });
    }
    setupDrag();
    updateDots();
  }

  function setupDrag() {
    if (!cards.length) return;

    drags.forEach(function(d) { d.kill(); });
    drags = [];
    wasDragged = false;

    var topIdx  = order[0];
    var topCard = cards[topIdx];
    if (!topCard) return;

    drags = Draggable.create(topCard, {
      type: 'x',
      edgeResistance: 0.55,
      minimumMovement: 8,
      onDragStart: function() { wasDragged = false; },
      onDrag: function() {
        wasDragged = true;
        var rot = (this.x / 260) * 20;
        gsap.set(topCard, { rotation: rot });
      },
      onDragEnd: function() {
        if (!wasDragged) return;
        if (Math.abs(this.x) > 70) {
          throwCard(this.x > 0 ? 1 : -1);
        } else {
          gsap.to(topCard, { x: 0, rotation: 0, duration: 0.5, ease: 'back.out(2.2)' });
        }
      },
    });
  }

  function throwCard(dir: number) {
    if (isAnimating || !cards.length) return;
    isAnimating = true;

    var topIdx  = order[0];
    var topCard = cards[topIdx];
    if (!topCard) {
      isAnimating = false;
      return;
    }

    // Quitar flip si está dado vuelta
    topCard.classList.remove('is-flipped');

    drags.forEach(function(d) { d.kill(); });
    drags = [];

    // Las cartas detrás suben un slot mientras la tope sale.
    // Incluimos también la del fondo para conservar 3 cartas visibles en el deck.
    for (var slot = 1; slot <= 3; slot++) {
      var next = STACK[slot - 1];
      gsap.to(cards[order[slot]], {
        y: next.y, rotation: next.rotation, scale: next.scale,
        opacity: next.opacity, zIndex: next.zIndex,
        duration: 0.50, ease: 'power2.out', delay: 0.06,
      });
    }

    // La carta tope sale volando
    gsap.to(topCard, {
      x: dir * 560,
      y: dir > 0 ? 50 : -30,
      rotation: dir * 28,
      opacity: 0,
      duration: 0.48,
      ease: 'power2.in',
      onComplete: function() {
        var moved = order.shift();
        if (moved === undefined) {
          isAnimating = false;
          return;
        }
        order.push(moved);

        // Resetear la carta que fue al fondo
        var bottomIdx = order[3];
        var bs = STACK[3];
        gsap.set(cards[bottomIdx], {
          x: 0, y: bs.y, rotation: bs.rotation,
          scale: bs.scale, opacity: 0, zIndex: bs.zIndex,
        });

        isAnimating = false;
        updateDots();
        setupDrag();
      },
    });
  }

  function updateDots() {
    var dots = document.querySelectorAll<HTMLElement>('.deck-dot');
    if (!dots.length) return;

    dots.forEach(function(dot, i) {
      var active = (order[0] === i);
      dot.style.width   = active ? '20px' : '8px';
      dot.style.opacity = active ? '1'    : '0.35';
    });
  }

  // Click → voltear (solo la carta del tope, solo si no fue arrastre)
  cards.forEach(function(card, i) {
    card.addEventListener('click', function() {
      if (wasDragged) { wasDragged = false; return; }
      if (order[0] !== i) return;
      card.classList.toggle('is-flipped');
    });
  });
</script>
