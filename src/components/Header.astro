---
const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Documentación', href: '/documentacion' },
  { label: 'Certificados', href: '/certificados' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-[var(--color-primary-navy)]"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group flex-shrink-0">
        <img
          src="/images/inicio/logo.png"
          alt="LLC Certificaciones"
          class="h-10 w-auto object-contain"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden xl:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-white text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-150"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Teléfono + toggle tema + mobile btn -->
      <div class="flex items-center gap-3">
        <a
          href="tel:3108369861"
          class="hidden md:flex items-center gap-2 text-[var(--color-accent-amber)] hover:text-[var(--color-accent-amber-hover)] font-600 text-sm transition-colors duration-150"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          310 836 9861
        </a>

        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Cambiar tema"
        >
          <svg id="icon-sun" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
          </svg>
          <svg id="icon-moon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
          </svg>
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="xl:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Abrir menú"
        >
          <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="xl:hidden border-t border-white/10 bg-[var(--color-primary-navy)] overflow-hidden"
    style="height:0; opacity:0;"
  >
    <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-nav-link text-slate-300 hover:text-white font-medium text-sm px-3 py-2.5 rounded-lg hover:bg-white/10 transition-all duration-150"
        >
          {link.label}
        </a>
      ))}
      <a
        href="tel:3108369861"
        class="mobile-nav-link flex items-center gap-2 text-[var(--color-accent-amber)] font-600 text-sm px-3 py-2.5 mt-2 border-t border-white/10"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        310 836 9861
      </a>
    </nav>
  </div>
</header>

<script>
  import gsap from 'gsap';

  // ── Theme Toggle ──
  const themeToggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  function updateToggleIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      iconSun?.classList.remove('hidden');
      iconMoon?.classList.add('hidden');
    } else {
      iconSun?.classList.add('hidden');
      iconMoon?.classList.remove('hidden');
    }
  }

  updateToggleIcons();

  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateToggleIcons();
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      if (e.matches) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      updateToggleIcons();
    }
  });

  // ── Mobile Menu ──
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  const links = document.querySelectorAll('.mobile-nav-link');

  var menuOpen = false;
  var animating = false;

  gsap.set(links, { opacity: 0, x: -16 });

  btn?.addEventListener('click', function() {
    if (animating) return;
    animating = true;

    if (!menuOpen) {
      iconMenu?.classList.add('hidden');
      iconClose?.classList.remove('hidden');

      gsap.to(menu, {
        height: 'auto',
        opacity: 1,
        duration: 0.28,
        ease: 'power2.out',
        onComplete: function() {
          menuOpen = true;
          animating = false;
        }
      });

      gsap.to(links, {
        opacity: 1,
        x: 0,
        duration: 0.25,
        stagger: 0.04,
        ease: 'power2.out',
        delay: 0.08,
      });

    } else {
      gsap.to(links, {
        opacity: 0,
        x: -12,
        duration: 0.18,
        stagger: 0.02,
        ease: 'power2.in',
      });

      gsap.to(menu, {
        height: 0,
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
        delay: 0.08,
        onComplete: function() {
          iconMenu?.classList.remove('hidden');
          iconClose?.classList.add('hidden');
          menuOpen = false;
          animating = false;
        }
      });
    }
  });

  // Scroll behavior: add shadow on scroll
  const header = document.getElementById('header');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-xl');
    } else {
      header?.classList.remove('shadow-xl');
    }
  });
</script>
