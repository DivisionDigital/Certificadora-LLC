---
const navLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Noticias', href: '#noticias' },
  { label: 'Documentación', href: '#documentacion' },
  { label: 'Consulta de Certificados', href: '#consulta' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-[#0B1F4B]"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group flex-shrink-0">
        <div class="w-9 h-9 rounded-lg bg-[#F59E0B] flex items-center justify-center">
          <svg class="w-5 h-5 text-[#0B1F4B]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <div class="flex flex-col leading-tight">
          <span class="text-white font-800 text-base tracking-tight">LLC</span>
          <span class="text-[#F59E0B] font-600 text-xs tracking-widest uppercase">Certificaciones</span>
        </div>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden xl:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-slate-300 hover:text-white text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/10 transition-all duration-150"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Teléfono + mobile btn -->
      <div class="flex items-center gap-4">
        <a
          href="tel:3108369861"
          class="hidden md:flex items-center gap-2 text-[#F59E0B] hover:text-[#FBBF24] font-600 text-sm transition-colors duration-150"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          310 836 9861
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="xl:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Abrir menú"
        >
          <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="xl:hidden hidden border-t border-white/10 bg-[#0B1F4B]"
  >
    <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-slate-300 hover:text-white font-medium text-sm px-3 py-2.5 rounded-lg hover:bg-white/10 transition-all duration-150"
        >
          {link.label}
        </a>
      ))}
      <a
        href="tel:3108369861"
        class="flex items-center gap-2 text-[#F59E0B] font-600 text-sm px-3 py-2.5 mt-2 border-t border-white/10"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        310 836 9861
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Scroll behavior: add shadow on scroll
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-xl');
    } else {
      header?.classList.remove('shadow-xl');
    }
  });
</script>
