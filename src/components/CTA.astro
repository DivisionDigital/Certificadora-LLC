---
---

<section id="contacto" class="py-24 lg:py-32 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- ═══════════════════════════════════════════════════════
           📸 SLOT DE IMAGEN — CONTACTO (columna izquierda)
           ─────────────────────────────────────────────────────
           Tamaño recomendado : 640 × 640 px  (ratio 1:1)
           Ruta del archivo   : /images/contacto.jpg
           Sugerencia         : foto de un asesor, reunión de equipo,
                                consultoría técnica o sede de LLC.
           ─────────────────────────────────────────────────────
           Cuando tengas la imagen, reemplaza TODO el bloque
           (desde este comentario hasta el cierre </div>)
           por:

           <div class="rounded-2xl overflow-hidden aspect-square">
             <img
               src="/images/contacto.jpg"
               alt="Equipo de asesores LLC Certificaciones"
               class="w-full h-full object-cover"
             />
           </div>
           ═══════════════════════════════════════════════════════ -->
      <div class="rounded-2xl overflow-hidden aspect-square bg-[var(--color-placeholder-bg)] border-2 border-dashed border-[var(--color-placeholder-border)] flex flex-col items-center justify-center gap-4 order-2 lg:order-1">
        <div class="w-16 h-16 rounded-2xl bg-[var(--color-light-blue-bg)] flex items-center justify-center">
          <svg class="w-8 h-8 text-[var(--color-placeholder-icon)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div class="text-center px-8">
          <p class="text-[var(--color-placeholder-text)] font-semibold text-sm mb-1">📸 Foto de contacto / equipo</p>
          <p class="text-[var(--color-placeholder-sub)] text-xs leading-relaxed">
            Reemplaza este bloque con tu foto<br/>
            <span class="font-mono text-[10px]">/images/contacto.jpg · 640 × 640 px</span>
          </p>
        </div>
      </div>

      <!-- Contenido de contacto -->
      <div class="order-1 lg:order-2">

        <!-- Ícono decorativo -->
        <div class="inline-flex w-14 h-14 bg-[var(--color-light-blue-bg)] rounded-2xl items-center justify-center mb-6">
          <svg class="w-7 h-7 text-[var(--color-primary-blue)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>

        <!-- Texto -->
        <span class="inline-block px-4 py-1.5 bg-[var(--color-badge-blue-bg)] text-[var(--color-primary-blue)] text-xs font-semibold rounded-full uppercase tracking-widest mb-4">
          Contáctenos
        </span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-[var(--color-text-primary)] mb-4">
          ¿Necesita certificar sus productos?
        </h2>
        <p class="text-[var(--color-text-muted)] text-base leading-relaxed mb-8">
          Un experto de LLC Certificaciones lo asesorará en el proceso de certificación RETIE,
          RETILAP, RETIQ o normas voluntarias más adecuado para su producto.
          Llámenos o escríbanos hoy mismo.
        </p>

        <!-- Acciones -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <a
            href="tel:3108369861"
            class="inline-flex items-center justify-center gap-3 px-7 py-4 bg-[var(--color-primary-navy)] hover:bg-[var(--color-primary-blue)] text-white font-bold rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            310 836 9861
          </a>
          <a
            href="#consulta"
            class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-[var(--color-accent-amber)] hover:bg-[var(--color-accent-amber-hover)] text-[var(--color-primary-navy)] font-bold rounded-xl transition-all duration-200 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Consultar Certificados
          </a>
        </div>

        <!-- Datos de contacto adicional -->
        <div class="flex flex-col gap-3 text-sm text-[var(--color-text-muted)]">
          <div class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-[var(--color-primary-blue)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Respuesta en menos de 24 horas
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-[var(--color-primary-blue)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Cobertura nacional
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-[var(--color-primary-blue)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            Asesoría sin costo inicial
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
