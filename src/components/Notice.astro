---
---

<section id="noticias" class="py-8 bg-[var(--color-surface-alt)] border-y border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-start md:items-center gap-5 p-6 bg-[var(--color-surface-card)] rounded-2xl border border-amber-200 shadow-sm">

      <!-- Ícono de alerta -->
      <div class="flex-shrink-0 w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center">
        <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>

      <!-- Contenido -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <span class="inline-block px-2.5 py-0.5 bg-amber-100 text-amber-800 text-xs font-semibold rounded-full uppercase tracking-wide">
            Aviso Normativo
          </span>
          <span class="text-[var(--color-text-faint)] text-xs">Actualización 2025</span>
        </div>
        <p class="text-[var(--color-text-primary)] font-semibold text-sm md:text-base leading-snug">
          El Ministerio de Minas y Energía amplió los plazos de certificación del reglamento
          <strong>RETIE anterior hasta el 31 de diciembre de 2025.</strong>
        </p>
        <p class="text-[var(--color-text-muted)] text-sm mt-1.5 leading-relaxed">
          LLC Certificaciones se encuentra finalizando su proceso de acreditación bajo el reglamento actualizado de 2024.
          Contáctenos para más información sobre cómo esto afecta su proceso de certificación.
        </p>
      </div>

      <!-- Acción -->
      <a
        href="#contacto"
        class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-primary-navy)] hover:bg-[var(--color-primary-blue)] text-white text-sm font-semibold rounded-xl transition-colors duration-200"
      >
        Más información
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
