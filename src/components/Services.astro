---
const services = [
  {
    badge: 'RETIE',
    badgeColor: 'bg-[var(--color-badge-blue-bg)] text-[var(--color-badge-blue-text)]',
    title: 'Certificación RETIE',
    description: 'Reglamento Técnico de Instalaciones Eléctricas. Certificamos materiales y equipos eléctricos para garantizar seguridad en instalaciones a nivel nacional.',
    products: ['Tubería conduit en acero y PVC', 'Cintas y accesorios eléctricos', 'Sensores de automatización', 'Motores eléctricos'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    iconBg: 'bg-[var(--color-badge-blue-bg)]',
    iconColor: '#1040A0',
    accentLine: '#1040A0',
    // 📸 IMAGEN TARJETA — ruta del archivo en public/images/
    // Reemplaza el valor de imgSrc con la ruta real. Ej: '/images/retie.jpg'
    // Tamaño recomendado: 800 × 400 px (ratio 2:1)
    imgSrc: '/images/inicio/card-retie.webp',
    imgAlt: 'Certificación RETIE — materiales eléctricos',
  },
  {
    badge: 'RETILAP',
    badgeColor: 'bg-[var(--color-badge-amber-bg)] text-[var(--color-badge-amber-text)]',
    title: 'Certificación RETILAP',
    description: 'Reglamento Técnico de Iluminación y Alumbrado Público. Verificamos eficiencia, seguridad y calidad lumínica de productos de iluminación.',
    products: ['Luminarias interiores', 'Luminarias exteriores', 'Sistemas de alumbrado público', 'Equipos LED y tecnologías emergentes'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
    iconBg: 'bg-[var(--color-badge-amber-bg)]',
    iconColor: '#D97706',
    accentLine: '#F59E0B',
    imgSrc: '/images/inicio/card-retilap.webp',
    imgAlt: 'Certificación RETILAP — iluminación y alumbrado',
  },
  {
    badge: 'RETIQ',
    badgeColor: 'bg-[var(--color-badge-emerald-bg)] text-[var(--color-badge-emerald-text)]',
    title: 'Certificación RETIQ',
    description: 'Reglamento Técnico de Etiquetado de Eficiencia Energética. Certificamos el consumo y eficiencia de equipos eléctricos y de gas para su correcta etiquetación.',
    products: ['Motores monofásicos', 'Motores trifásicos', 'Electrodomésticos', 'Equipos de calentamiento'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
    iconBg: 'bg-[var(--color-badge-emerald-bg)]',
    iconColor: '#059669',
    accentLine: '#10B981',
    imgSrc: '/images/inicio/card-retiq.webp',
    imgAlt: 'Certificación RETIQ — etiquetado energético',
  },
  {
    badge: 'Normas Voluntarias',
    badgeColor: 'bg-violet-50 text-violet-700',
    title: 'Normas Voluntarias',
    description: 'Certificación bajo estándares técnicos voluntarios nacionales e internacionales, para productos que buscan diferenciarse por calidad y cumplimiento técnico.',
    products: ['Accesorios para gas', 'Transformadores eléctricos', 'Postes de concreto', 'Tableros eléctricos de baja tensión'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>`,
    iconBg: 'bg-violet-50',
    iconColor: '#7C3AED',
    accentLine: '#8B5CF6',
    imgSrc: '/images/inicio/card-nv.webp',
    imgAlt: 'Normas Voluntarias — certificación técnica',
  },
];
---

<section id="servicios" class="py-24 lg:py-32 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Encabezado de sección -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-badge-blue-bg)] text-[var(--color-primary-blue)] text-xs font-semibold rounded-full uppercase tracking-widest mb-4">
        Nuestros Servicios
      </span>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-[var(--color-text-primary)] mb-4">
        Certificaciones que respaldan<br class="hidden md:block"/> su producto en el mercado
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto leading-relaxed">
        Somos su aliado técnico para cumplir con los reglamentos técnicos colombianos
        y obtener las certificaciones necesarias para comercializar sus productos.
      </p>
    </div>

    <!-- Grid de tarjetas -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(service => (
        <article class="group relative bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-200 hover:border-[var(--color-border-hover)] overflow-hidden">

          <!-- Línea de acento superior (sobre imagen o borde) -->
          <div
            class="absolute top-0 left-0 right-0 h-1 z-10 rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-200"
            style={`background: ${service.accentLine};`}
          ></div>

          <!-- ═══════════════════════════════════════════════════════
               📸 SLOT DE IMAGEN — TARJETA {service.title}
               ─────────────────────────────────────────────────────
               Tamaño recomendado : 800 × 400 px  (ratio 2:1)
               Para agregar la imagen, edita el objeto en el array
               services[] arriba y cambia el campo imgSrc:
                 imgSrc: '/images/retie.jpg'   ← pon la ruta aquí
               ═══════════════════════════════════════════════════════ -->
          {service.imgSrc ? (
            <div class="w-full aspect-video overflow-hidden">
              <img
                src={service.imgSrc}
                alt={service.imgAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
          ) : (
            <div class="w-full aspect-video bg-[var(--color-placeholder-bg)] border-b border-[var(--color-border)] flex flex-col items-center justify-center gap-2">
              <svg class="w-7 h-7 text-[var(--color-border-dark)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-[var(--color-text-faint)] text-xs font-medium">📸 {service.badge} — imagen del servicio</span>
              <span class="text-[var(--color-border-dark)] font-mono text-[10px]">imgSrc: '/images/...' · 800×400 px</span>
            </div>
          )}

          <!-- Contenido de la tarjeta -->
          <div class="p-8">

          <!-- Header de tarjeta -->
          <div class="flex items-start gap-4 mb-6">
            <div class={`w-14 h-14 ${service.iconBg} rounded-xl flex items-center justify-center flex-shrink-0`}>
              <svg
                class="w-7 h-7"
                fill="none"
                stroke={service.iconColor}
                stroke-width="1.75"
                viewBox="0 0 24 24"
                set:html={service.icon}
              />
            </div>
            <div>
              <span class={`inline-block px-3 py-1 text-xs font-semibold rounded-full mb-2 ${service.badgeColor}`}>
                {service.badge}
              </span>
              <h3 class="text-xl font-bold text-[var(--color-text-primary)]">{service.title}</h3>
            </div>
          </div>

          <!-- Descripción -->
          <p class="text-[var(--color-text-muted)] leading-relaxed mb-6 text-sm">
            {service.description}
          </p>

          <!-- Lista de productos -->
          <div>
            <p class="text-xs font-semibold text-[var(--color-text-faint)] uppercase tracking-widest mb-3">
              Productos certificados
            </p>
            <ul class="space-y-2">
              {service.products.map(product => (
                <li class="flex items-center gap-2.5 text-sm text-[var(--color-text-body)]">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke={service.accentLine} stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  {product}
                </li>
              ))}
            </ul>
          </div>

          <!-- Enlace -->
          <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
            <a
              href="#contacto"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-primary-blue)] hover:text-[var(--color-primary-hover)] transition-colors"
            >
              Solicitar información
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-150" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>

          </div>{/* fin div.p-8 */}
        </article>
      ))}
    </div>
  </div>
</section>
