---
const quickLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Noticias', href: '#noticias' },
  { label: 'Documentación', href: '#documentacion' },
  { label: 'Consulta de Certificados', href: '#consulta' },
];

const certifications = [
  { label: 'RETIE', href: '#servicios' },
  { label: 'RETILAP', href: '#servicios' },
  { label: 'RETIQ', href: '#servicios' },
  { label: 'Normas Voluntarias', href: '#servicios' },
];
---

<footer class="bg-[#0B1F4B] text-white">

  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Marca -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl bg-[#F59E0B] flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#0B1F4B]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-white font-bold text-lg tracking-tight">LLC Certificaciones</span>
            <span class="text-[#F59E0B] text-xs font-medium tracking-widest uppercase">Certificadora técnica nacional</span>
          </div>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed max-w-sm mb-6">
          Aliado estratégico para la certificación de productos eléctricos, electrónicos
          e iluminación bajo los reglamentos técnicos colombianos RETIE, RETILAP y RETIQ.
        </p>
        <!-- Contacto principal -->
        <div class="space-y-3">
          <a href="tel:3108369861" class="flex items-center gap-3 text-slate-300 hover:text-[#F59E0B] transition-colors text-sm group">
            <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center group-hover:bg-[#F59E0B]/20 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            310 836 9861
          </a>
          <div class="flex items-center gap-3 text-slate-400 text-sm">
            <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            Colombia — Cobertura nacional
          </div>
        </div>
      </div>

      <!-- Col 2: Links rápidos -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-widest mb-5">
          Navegación
        </h4>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-slate-400 hover:text-white text-sm transition-colors duration-150 flex items-center gap-2 group"
              >
                <svg class="w-3 h-3 text-[#F59E0B] opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M13 7l5 5m0 0l-5 5m5-5H6" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Certificaciones -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-widest mb-5">
          Certificaciones
        </h4>
        <ul class="space-y-3">
          {certifications.map(cert => (
            <li>
              <a
                href={cert.href}
                class="text-slate-400 hover:text-white text-sm transition-colors duration-150 flex items-center gap-2 group"
              >
                <svg class="w-3 h-3 text-[#F59E0B] opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
                {cert.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- CTA pequeño -->
        <div class="mt-8 p-4 bg-white/5 rounded-xl border border-white/10">
          <p class="text-slate-300 text-xs mb-3 leading-relaxed">
            ¿Listo para certificar su producto?
          </p>
          <a
            href="#contacto"
            class="inline-flex items-center gap-1.5 text-[#F59E0B] hover:text-[#FBBF24] font-semibold text-xs transition-colors"
          >
            Contáctenos hoy
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-slate-500 text-xs">
        © 2025 LLC Certificaciones. Todos los derechos reservados.
      </p>
      <p class="text-slate-600 text-xs">
        Certificadora de materiales eléctricos — Colombia
      </p>
    </div>
  </div>
</footer>
