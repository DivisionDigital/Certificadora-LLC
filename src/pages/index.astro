---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Notice from '../components/Notice.astro';
import Trust from '../components/Trust.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="LLC Certificaciones — RETIE, RETILAP, RETIQ en Colombia"
  description="Aliado estratégico para la certificación de productos eléctricos, electrónicos e iluminación. RETIE, RETILAP, RETIQ y normas voluntarias a nivel nacional."
>
  <Header />
  <Hero />
  <Notice />
  <Services />
  <Trust />
  <CTA />
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var sections = ['#noticias', '#servicios', '#nosotros', '#contacto']
    .map(function(selector) {
      return document.querySelector<HTMLElement>(selector);
    })
    .filter(function(section): section is HTMLElement {
      return section !== null;
    });

  if (!prefersReducedMotion && sections.length) {
    sections.forEach(function(section) {
      gsap.set(section, { opacity: 0, y: 56 });

      gsap.to(section, {
        opacity: 1,
        y: 0,
        duration: 0.85,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 82%',
          once: true,
        },
      });
    });
  }
</script>
