---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Notice from '../components/Notice.astro';
import Trust from '../components/Trust.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="LLC Certificaciones — RETIE, RETILAP, RETIQ en Colombia"
  description="Aliado estratégico para la certificación de productos eléctricos, electrónicos e iluminación. RETIE, RETILAP, RETIQ y normas voluntarias a nivel nacional."
>
  <Header />
  <Hero />
  <Notice />
  <Services />
  <Trust />
  <CTA />
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const sections = ['#noticias', '#servicios', '#nosotros', '#contacto']
    .map((s) => document.querySelector<HTMLElement>(s))
    .filter((el): el is HTMLElement => el !== null);

  if (!prefersReducedMotion && sections.length) {
    sections.forEach((section) => {
      // Si la sección ya está visible al cargar, no animarla
      const rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.9) {
        section.style.opacity = '1';
        return;
      }

      gsap.set(section, { opacity: 0, y: 40 });

      ScrollTrigger.create({
        trigger: section,
        start: 'top 90%',
        once: true,
        onEnter: () => {
          gsap.to(section, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power2.out',
          });
        },
      });
    });
  }

  window.addEventListener('load', () => ScrollTrigger.refresh());
</script>
