---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Nosotros — LLC Certificaciones"
  description="Conoce la misión, visión, política integral y objetivos de LLC Certificaciones. Organismo de certificación de productos acreditado bajo ISO/IEC 17065."
>
  <Header />

  <!-- ═══ Hero banner de página ═══ -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden" style="background: linear-gradient(135deg, #0B1F4B 0%, #0D2860 50%, #1040A0 100%);">
    <!-- Patrón de fondo -->
    <div class="absolute inset-0 opacity-[0.05]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-n" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-n)"/>
      </svg>
    </div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-10" style="background:radial-gradient(circle,#1E6FE8 0%,transparent 70%); transform:translate(30%,-40%);" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm mb-8">
        <a href="/" class="text-slate-400 hover:text-white transition-colors">Inicio</a>
        <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-white font-medium">Nosotros</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 mb-6">
          <svg class="w-4 h-4 text-[#F59E0B]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <span class="text-white/90 text-sm font-medium">Organismo de certificación acreditado</span>
        </div>
        <h1 class="text-white font-extrabold leading-tight mb-5" style="font-size: clamp(2.25rem, 5vw, 3.25rem);">
          Conoce quiénes somos y nuestro <span class="text-[#F59E0B]">compromiso</span> con la calidad
        </h1>
        <p class="text-slate-300 text-lg leading-relaxed max-w-2xl">
          LLC es un organismo de certificación de productos comprometido con la evaluación de conformidad bajo los más altos estándares internacionales.
        </p>
      </div>
    </div>

    <!-- Wave -->
    <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 60L1440 60L1440 30C1200 60 960 0 720 20C480 40 240 10 0 30L0 60Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ═══ Misión y Visión ═══ -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Misión -->
        <div class="group p-8 lg:p-10 rounded-2xl border border-[#E2E8F0] hover:border-[#1040A0]/30 bg-white hover:shadow-lg transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-[#1040A0]/10 flex items-center justify-center mb-6 group-hover:bg-[#1040A0]/15 transition-colors">
            <svg class="w-7 h-7 text-[#1040A0]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-[#0F172A] font-bold text-2xl">Misión</h2>
            <div class="h-px flex-1 bg-[#E2E8F0]"></div>
          </div>
          <p class="text-[#334155] leading-relaxed">
            Prestar el servicio de evaluación de la conformidad de productos dando cumplimiento con los requisitos de la
            <strong class="text-[#1040A0] font-semibold">ISO/IEC 17065</strong>, los requisitos legales y reglamentarios aplicables,
            agregando valor a nuestros clientes ofreciéndoles procesos de evaluación de conformidad oportunos y confiables,
            orientados en la seguridad y el desempeño de sus productos.
          </p>
        </div>

        <!-- Visión -->
        <div class="group p-8 lg:p-10 rounded-2xl border border-[#E2E8F0] hover:border-[#F59E0B]/30 bg-white hover:shadow-lg transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-[#F59E0B]/10 flex items-center justify-center mb-6 group-hover:bg-[#F59E0B]/15 transition-colors">
            <svg class="w-7 h-7 text-[#F59E0B]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-[#0F172A] font-bold text-2xl">Visión</h2>
            <div class="h-px flex-1 bg-[#E2E8F0]"></div>
          </div>
          <p class="text-[#334155] leading-relaxed">
            Fortalecer el liderazgo a nivel nacional por medio de la ampliación de nuestro alcance de certificación
            de productos bajo otros requisitos legales o normativos, a través del
            <strong class="text-[#1040A0] font-semibold">crecimiento constante de un talento humano</strong>
            que contribuya al desarrollo empresarial.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Política Integral ═══ -->
  <section class="py-20 lg:py-28 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase text-[#1040A0] bg-[#DBEAFE] mb-4">
          Nuestros pilares
        </span>
        <h2 class="text-[#0F172A] font-bold leading-tight" style="font-size: clamp(1.75rem, 3.5vw, 2.25rem);">
          Política Integral
        </h2>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="p-8 lg:p-10 rounded-2xl bg-white border border-[#E2E8F0] shadow-sm mb-6">
          <p class="text-[#334155] leading-relaxed mb-8">
            La Junta Directiva de LLC ha definido, revisado y aprobado la siguiente política integral:
          </p>

          <div class="space-y-5">
            <div class="flex gap-4 items-start">
              <div class="w-8 h-8 rounded-lg bg-[#1040A0] flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-white font-bold text-sm">1</span>
              </div>
              <p class="text-[#334155] leading-relaxed">
                Prestar el servicio de evaluación de la conformidad de productos dando cumplimiento con los requisitos de la
                <strong class="font-semibold text-[#0F172A]">ISO/IEC 17065</strong>, los requisitos legales y reglamentarios aplicables
                y las directrices para los esquemas de certificación según el alcance de LLC bajo la
                <strong class="font-semibold text-[#0F172A]">ISO/IEC 17067</strong>.
              </p>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-8 h-8 rounded-lg bg-[#1040A0] flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-white font-bold text-sm">2</span>
              </div>
              <p class="text-[#334155] leading-relaxed">
                Desarrollar e implementar un <strong class="font-semibold text-[#0F172A]">sistema de gestión integrado</strong> eficaz y eficiente.
              </p>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-8 h-8 rounded-lg bg-[#1040A0] flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-white font-bold text-sm">3</span>
              </div>
              <p class="text-[#334155] leading-relaxed">
                Implementar la <strong class="font-semibold text-[#0F172A]">mejora continua</strong> del sistema de gestión integrado.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Objetivos ═══ -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase text-[#F59E0B] bg-[#FEF3C7] mb-4">
          Compromisos
        </span>
        <h2 class="text-[#0F172A] font-bold leading-tight" style="font-size: clamp(1.75rem, 3.5vw, 2.25rem);">
          Objetivos Específicos
        </h2>
        <p class="text-[#64748B] mt-3 max-w-2xl mx-auto">
          La Junta Directiva de LLC ha definido, revisado y aprobado los siguientes objetivos específicos.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">

        <!-- Objetivo 1 -->
        <div class="group p-7 rounded-2xl border border-[#E2E8F0] hover:border-[#1040A0]/25 hover:shadow-md transition-all duration-300 bg-white">
          <div class="w-10 h-10 rounded-xl bg-[#DBEAFE] flex items-center justify-center mb-5 group-hover:bg-[#1040A0]/15 transition-colors">
            <svg class="w-5 h-5 text-[#1040A0]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/>
            </svg>
          </div>
          <h3 class="text-[#0F172A] font-semibold text-base mb-2">Satisfacción del cliente</h3>
          <p class="text-[#64748B] text-sm leading-relaxed">
            Obtener la satisfacción del cliente cumpliendo con los acuerdos comerciales, los requisitos de la ISO/IEC 17065
            y las directrices para los esquemas de certificación bajo la ISO/IEC 17067.
          </p>
        </div>

        <!-- Objetivo 2 -->
        <div class="group p-7 rounded-2xl border border-[#E2E8F0] hover:border-[#1040A0]/25 hover:shadow-md transition-all duration-300 bg-white">
          <div class="w-10 h-10 rounded-xl bg-[#DBEAFE] flex items-center justify-center mb-5 group-hover:bg-[#1040A0]/15 transition-colors">
            <svg class="w-5 h-5 text-[#1040A0]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
          </div>
          <h3 class="text-[#0F172A] font-semibold text-base mb-2">Imparcialidad y confiabilidad</h3>
          <p class="text-[#64748B] text-sm leading-relaxed">
            Garantizar la imparcialidad, independencia, confiabilidad y confidencialidad durante la prestación del servicio
            de evaluación de la conformidad de productos según el alcance de LLC.
          </p>
        </div>

        <!-- Objetivo 3 -->
        <div class="group p-7 rounded-2xl border border-[#E2E8F0] hover:border-[#1040A0]/25 hover:shadow-md transition-all duration-300 bg-white">
          <div class="w-10 h-10 rounded-xl bg-[#DBEAFE] flex items-center justify-center mb-5 group-hover:bg-[#1040A0]/15 transition-colors">
            <svg class="w-5 h-5 text-[#1040A0]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
            </svg>
          </div>
          <h3 class="text-[#0F172A] font-semibold text-base mb-2">Competencia del personal</h3>
          <p class="text-[#64748B] text-sm leading-relaxed">
            Garantizar las competencias del personal a nivel organizacional para la prestación
            del servicio de evaluación de conformidad.
          </p>
        </div>

        <!-- Objetivo 4 -->
        <div class="group p-7 rounded-2xl border border-[#E2E8F0] hover:border-[#1040A0]/25 hover:shadow-md transition-all duration-300 bg-white">
          <div class="w-10 h-10 rounded-xl bg-[#FEF3C7] flex items-center justify-center mb-5 group-hover:bg-[#F59E0B]/15 transition-colors">
            <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"/>
            </svg>
          </div>
          <h3 class="text-[#0F172A] font-semibold text-base mb-2">Eficacia del sistema</h3>
          <p class="text-[#64748B] text-sm leading-relaxed">
            Garantizar la eficacia y efectividad del Sistema de Gestión integrado
            en todos los procesos de la organización.
          </p>
        </div>

        <!-- Objetivo 5 -->
        <div class="group p-7 rounded-2xl border border-[#E2E8F0] hover:border-[#1040A0]/25 hover:shadow-md transition-all duration-300 bg-white md:col-span-2 lg:col-span-2">
          <div class="w-10 h-10 rounded-xl bg-[#FEF3C7] flex items-center justify-center mb-5 group-hover:bg-[#F59E0B]/15 transition-colors">
            <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/>
            </svg>
          </div>
          <h3 class="text-[#0F172A] font-semibold text-base mb-2">Mejora continua</h3>
          <p class="text-[#64748B] text-sm leading-relaxed max-w-xl">
            Mantener la mejora continua del Sistema de Gestión integrado con el compromiso de la alta dirección
            y de todo el personal involucrado en los procesos de certificación.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Dato importante ═══ -->
  <section class="py-16 lg:py-20" style="background: linear-gradient(135deg, #0B1F4B 0%, #1040A0 100%);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#F59E0B]/15 border border-[#F59E0B]/30 mb-6">
          <svg class="w-4 h-4 text-[#F59E0B]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
          <span class="text-[#F59E0B] text-sm font-semibold">Dato importante</span>
        </div>

        <p class="text-white text-lg lg:text-xl leading-relaxed mb-8">
          Para la evaluación de conformidad de tu producto según <strong class="text-[#F59E0B]">Esquema 5 RETIE</strong>,
          debes tener tu Sistema de Gestión de la Calidad certificado.
          Consulta el reglamento <strong class="text-[#F59E0B]">4.2.7.3 Esquema 5 RETIE</strong>.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="tel:3108369861"
            class="inline-flex items-center gap-2 px-7 py-4 bg-[#F59E0B] hover:bg-[#FBBF24] text-[#0B1F4B] font-bold rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Llámanos: 310 836 9861
          </a>
          <a
            href="/"
            class="inline-flex items-center gap-2 px-7 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl border border-white/30 hover:border-white/50 transition-all duration-200 hover:-translate-y-0.5"
          >
            Ver servicios
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
